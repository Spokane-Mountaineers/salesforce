# Schema for per-environment dotenv files.
#
# Copy this to one or more of:
#   .env.staging      # values for the sandbox org
#   .env.production   # values for the live org
#
# direnv loads .env.${SF_ENV} based on the SF_ENV switcher (see .envrc).
# All listed files are gitignored.

# Salesforce org alias (must exist in `sf org list`)
#   staging:    staging
#   production: production
SF_TARGET_ORG=

# Salesforce username that AuthProviders execute as.
#   staging:    webdev5@spokanemountaineers.org.staging
#   production: webdev5@spokanemountaineers.org
SF_EXECUTION_USER=

# ── LWR Experience site (docs/plans/2026-06-08-lwr-site-overhaul.md) ──────────
# Identity of the LWR site for the create/refresh/deploy/publish recipes. Names
# differ by org; the recipes act on the active SF_ENV (no per-recipe org arg).
#
# SITE_NAME            - display name (Network/CustomSite masterLabel), also the
#                        --name passed to `sf community create` / `community publish`
# SITE_BUNDLE          - DigitalExperienceBundle fullName (site/<ApiName>), used
#                        by `just refresh`. Derived from SITE_NAME at create time.
# SITE_URL_PATH_PREFIX - url path appended to the org domain (staging only; prod
#                        cutover to root is a separate Phase 6 step). 'lwr' is
#                        reserved by Salesforce — staging uses 'lwrsite'.
# SITE_TEMPLATE        - template for `sf community create`
# SITE_AUTH_TYPE       - AUTHENTICATED | AUTHENTICATED_WITH_PUBLIC_ACCESS_ENABLED
#                        | UNAUTHENTICATED (this site mixes public + member pages)
SITE_NAME=
SITE_BUNDLE=
SITE_URL_PATH_PREFIX=
SITE_TEMPLATE=Build Your Own (LWR)
SITE_AUTH_TYPE=AUTHENTICATED_WITH_PUBLIC_ACCESS_ENABLED

# Org-specific values rendered into the Network/CustomSite templates by
# `just deploy-site-config` (force-app networks/** + sites/** are ${VAR}
# templates, .forceignored so a refresh never clobbers them).
SITE_ADMIN_EMAIL=
# SITE_SENDER_EMAIL must be a VERIFIED Org-Wide Email Address (Setup > Email >
# Org-Wide Addresses). Experience Cloud silently drops forgot-password and
# welcome emails when the site's sender isn't a verified org-wide address.
SITE_SENDER_EMAIL=

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
# Required to deploy the Google AuthProvider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Identity Platform / Entra App Registration.
# Managed by Terraform/OpenTofu in github.com/Spokane-Mountaineers/infrastructure.
# Get values via:
#   cd infrastructure/terraform/environments/<env>
#   tofu output -raw client_id
#   tofu output -raw client_secret
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=

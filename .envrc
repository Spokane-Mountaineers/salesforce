# Salesforce dev environment loader (direnv).
#
# Pattern 1 (default — file-based switcher):
#   Set SF_ENV in .envrc.local (gitignored), e.g. `export SF_ENV=production`.
#   Falls back to staging if .envrc.local is missing or doesn't set SF_ENV.
#   See .envrc.local.example.
#
# Pattern 3 (one-shot override):
#   SF_ENV=production direnv exec . just deploy-microsoft-auth
#   just deploy-microsoft-auth SF_ENV=production
#
# Per-env values live in .env.<SF_ENV> (gitignored). See .env.example for the
# full schema.

# If SF_ENV came in from the calling shell (Pattern 3), respect it. Otherwise
# pick it up from .envrc.local (Pattern 1) and default to staging.
if [ -z "${SF_ENV:-}" ]; then
  source_env_if_exists .envrc.local
  : "${SF_ENV:=staging}"
fi
export SF_ENV

# Re-evaluate when the switcher or the per-env dotenv changes.
watch_file .envrc.local
watch_file ".env.${SF_ENV}"

dotenv_if_exists ".env.${SF_ENV}"

echo "direnv: SF_ENV=${SF_ENV}"
use flake

<?xml version="1.0" encoding="UTF-8" ?>
<AuthProvider xmlns="http://soap.sforce.com/2006/04/metadata">
    <authorizeUrl
  >https://login.microsoftonline.com/common/oauth2/v2.0/authorize?prompt=select_account</authorizeUrl>
    <consumerKey>${MICROSOFT_ENTRA_CLIENT_ID}</consumerKey>
    <consumerSecret>${MICROSOFT_ENTRA_CLIENT_SECRET}</consumerSecret>
    <defaultScopes>openid email profile</defaultScopes>
    <executionUser>${SF_EXECUTION_USER}</executionUser>
    <friendlyName>Microsoft</friendlyName>
    <includeOrgIdInIdentifier>false</includeOrgIdInIdentifier>
    <isPkceEnabled>true</isPkceEnabled>
    <providerType>OpenIdConnect</providerType>
    <registrationHandler>MicrosoftAuthRegistrationHandler</registrationHandler>
    <requireMfa>false</requireMfa>
    <sendAccessTokenInHeader>true</sendAccessTokenInHeader>
    <sendClientCredentialsInHeader>false</sendClientCredentialsInHeader>
    <sendSecretInApis>true</sendSecretInApis>
    <tokenUrl
  >https://login.microsoftonline.com/common/oauth2/v2.0/token</tokenUrl>
    <userInfoUrl>https://graph.microsoft.com/oidc/userinfo</userInfoUrl>
</AuthProvider>

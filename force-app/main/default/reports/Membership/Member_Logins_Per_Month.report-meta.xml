<?xml version="1.0" encoding="UTF-8" ?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Member Logins Per Month</name>
    <description
  >Total member logins per month, summed from the durable Member Login Month rollup (staff/integration/test already excluded). Drill a month for per-member counts, sorted by logins descending. Feeds the Membership dashboard.</description>
    <reportType>Member_Login_Month__c</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Month</dateGranularity>
        <field>Member_Login_Month__c$Month__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>Member_Login_Month__c$Member_Link__c</field>
    </columns>
    <columns>
        <field>Member_Login_Month__c$Login_Count__c</field>
        <aggregateTypes>Sum</aggregateTypes>
    </columns>
    <scope>organization</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <sortColumn>Member_Login_Month__c$Login_Count__c</sortColumn>
    <sortOrder>Desc</sortOrder>
    <timeFrameFilter>
        <dateColumn>Member_Login_Month__c$Month__c</dateColumn>
        <interval>INTERVAL_CUSTOM</interval>
    </timeFrameFilter>
</Report>

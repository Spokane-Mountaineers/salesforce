<?xml version="1.0" encoding="UTF-8" ?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Active Members Per Month</name>
    <description
  >Active members per month (record count) from the durable Active Member Month rollup (won memberships; test accounts excluded). Drill a month to see who was active. Starts June 2021, the earliest the Donorbox/Salesforce data is reliable.</description>
    <reportType>Active_Member_Month__c</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Month</dateGranularity>
        <field>Active_Member_Month__c$Month__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>Active_Member_Month__c$Member_Link__c</field>
    </columns>
    <columns>
        <field>Active_Member_Month__c$Last_Name__c</field>
    </columns>
    <scope>organization</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <sortColumn>Active_Member_Month__c$Last_Name__c</sortColumn>
    <sortOrder>Asc</sortOrder>
    <timeFrameFilter>
        <dateColumn>Active_Member_Month__c$Month__c</dateColumn>
        <interval>INTERVAL_CUSTOM</interval>
        <startDate>2021-06-01</startDate>
    </timeFrameFilter>
</Report>

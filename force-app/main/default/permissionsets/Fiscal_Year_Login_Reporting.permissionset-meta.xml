<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Fiscal Year Login Reporting</label>
    <description
  >Read access to the per-user fiscal-year login count fields and the Fiscal_Year_Login_History__c object, for admins who run the Community User Login Counts report.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <fieldPermissions>
        <field>User.Fiscal_Year_Login_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>User.Fiscal_Year_Login_Count_Updated__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Fiscal_Year_Login_History__c.Login_Type__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Fiscal_Year_Login_History__c.Status__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Fiscal_Year_Login_History__c.Application__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Fiscal_Year_Login_History__c.Source_Ip__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Fiscal_Year_Login_History__c.User__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <objectPermissions>
        <object>Fiscal_Year_Login_History__c</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
</PermissionSet>

<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Trip Report Author</label>
    <description
  >Lets active members author trip reports (plan §3.3): Create/Read/Edit on Content_Post__c + fields so the authoring LWC's insert-as-user succeeds. Trip Report record-type scope is enforced in ContentPostController. No delete/modifyAll.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Content_Post__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Content_Tag__c</object>
        <allowCreate>false</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Content_Post_Tag__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Activity__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Body__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Difficulty__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Free_Tags__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Location__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Publish_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Content_Post__c.Trip_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- Title__c, Status__c, Visibility__c are required fields; FLS can't be
         set on them (they're implicitly editable on create) and the Trip Report
         Author needs object Create which covers them. -->
</PermissionSet>

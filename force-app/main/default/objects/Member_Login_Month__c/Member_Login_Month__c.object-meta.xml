<?xml version="1.0" encoding="UTF-8" ?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description
  >Durable monthly login rollup: one row per member per month with that member's login count, summed from Fiscal_Year_Login_History__c by LoginRollupBatch. Persists after LoginHistoryCleanupBatch purges the mirror; backs the Member Logins Per Month chart and per-member drill.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <label>Member Login Month</label>
    <nameField>
        <displayFormat>MLM-{0000}</displayFormat>
        <label>Member Login Month Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Member Login Months</pluralLabel>
    <searchLayouts />
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>

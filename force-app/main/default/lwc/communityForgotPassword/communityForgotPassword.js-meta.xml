<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Community Forgot Password</masterLabel>
    <description
  >Alpine Field Guide forgot-password for the LWR site (plan §8): Site.forgotPassword via CommunityLoginController, matching the login card.</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property
        name="heading"
        type="String"
        label="Heading"
        default="Reset your password"
      />
            <property
        name="backgroundUrl"
        type="String"
        label="Background photo URL (optional)"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>

# List files or directories below to ignore them when running force:source:push, force:source:pull, and force:source:status
# More information: https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm
#

package.xml

# Auth Providers - tracked locally as templates with ${VAR} placeholders.
# Excluded from routine sf push/pull/retrieve so the consumerSecret in the
# org is never clobbered with `Placeholder_Value`. Deploy via:
#   just deploy-authproviders
# which renders the templates with values from .env (loaded by direnv).
force-app/main/default/authproviders/**

# Experience site config — tracked as ${VAR} templates (staff emails, url
# prefix) and excluded from routine sf push/pull/retrieve so the placeholders
# never overwrite real org values, and a `just refresh` of the bundle never
# clobbers them. Render + deploy with `just deploy-site-config`.
force-app/main/default/networks/**
force-app/main/default/sites/**

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**